{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "findings",
    "fix_plan",
    "rerun_review"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "clean",
        "has_findings"
      ]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "why_it_matters",
          "file",
          "line",
          "fix_instructions",
          "confidence"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "line": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "fix_instructions": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "fix_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rerun_review": {
      "type": "boolean"
    }
  }
}
